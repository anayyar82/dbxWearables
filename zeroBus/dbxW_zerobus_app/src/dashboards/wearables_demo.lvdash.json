{
  "datasets": [
    {
      "name": "d001",
      "displayName": "kpi_gold_rowcounts",
      "query": "\nSELECT 'activity_enriched_daily' AS entity, COUNT(*) AS c FROM users.ankur_nayyar.wearable_gold_activity_enriched_daily\nUNION ALL SELECT 'sleep_nightly', COUNT(*) FROM users.ankur_nayyar.wearable_gold_sleep_nightly\nUNION ALL SELECT 'weekly_workouts', COUNT(*) FROM users.ankur_nayyar.wearable_gold_weekly_workout_summary\nUNION ALL SELECT 'cardio_vitals_daily', COUNT(*) FROM users.ankur_nayyar.wearable_gold_cardio_vitals_daily\nUNION ALL SELECT 'hk_family_weekly', COUNT(*) FROM users.ankur_nayyar.wearable_gold_hk_family_weekly\n",
      "parameters": []
    },
    {
      "name": "d002",
      "displayName": "activity_move_trend",
      "query": "\nSELECT day, user_id, move_ring_ratio, total_steps, exercise_ring_ratio, stand_ring_ratio\nFROM users.ankur_nayyar.wearable_vw_gold_activity_last_45d\nWHERE day >= current_date() - INTERVAL 45 DAY\nORDER BY day\n",
      "parameters": []
    },
    {
      "name": "d003",
      "displayName": "sleep_stage_totals",
      "query": "\nSELECT sleep_night, user_id, deep_sleep_min, rem_sleep_min, core_sleep_min, awake_min, total_tracked_min\nFROM users.ankur_nayyar.wearable_vw_gold_sleep_last_30_sessions\nORDER BY sleep_night DESC\n",
      "parameters": []
    },
    {
      "name": "d004",
      "displayName": "workout_weekly_bars",
      "query": "\nSELECT week_start, user_id, workout_count, total_duration_min, total_energy_kcal, total_distance_m / 1000.0 AS distance_km\nFROM users.ankur_nayyar.wearable_vw_gold_workouts_recent\nORDER BY week_start\n",
      "parameters": []
    },
    {
      "name": "d005",
      "displayName": "vitals_hr_trend",
      "query": "\nSELECT day, user_id, resting_hr_avg, heart_rate_avg, heart_rate_max, hrv_sdnn_avg, spo2_avg\nFROM users.ankur_nayyar.wearable_gold_cardio_vitals_daily\nWHERE day >= current_date() - INTERVAL 60 DAY\nORDER BY day\n",
      "parameters": []
    },
    {
      "name": "d006",
      "displayName": "hk_family_weekly_lines",
      "query": "\nSELECT week_start, user_id, metric_family,\n  concat(user_id, ' | ', metric_family) AS series_key,\n  avg_value, readings\nFROM users.ankur_nayyar.wearable_gold_hk_family_weekly\nWHERE week_start >= current_timestamp() - INTERVAL 84 DAY\nORDER BY week_start, metric_family\n",
      "parameters": []
    },
    {
      "name": "d007",
      "displayName": "ingest_mix",
      "query": "\nSELECT ingest_day, user_id, record_type, row_count\nFROM users.ankur_nayyar.wearable_gold_bronze_ingest_daily\nWHERE ingest_day >= current_date() - INTERVAL 60 DAY\nORDER BY ingest_day DESC, row_count DESC\n",
      "parameters": []
    },
    {
      "name": "d008",
      "displayName": "daily_steps",
      "query": "\nSELECT day, user_id, total_steps, sample_intervals\nFROM users.ankur_nayyar.wearable_gold_daily_steps\nWHERE day >= current_date() - INTERVAL 60 DAY\nORDER BY day\n",
      "parameters": []
    },
    {
      "name": "d009",
      "displayName": "hk_quantity_daily_top",
      "query": "\nSELECT day, user_id, regexp_replace(hk_type,'HKQuantityTypeIdentifier','') AS metric, avg_value, sample_rows\nFROM users.ankur_nayyar.wearable_hk_quantity_daily_gold\nWHERE day >= current_date() - INTERVAL 45 DAY\nORDER BY sample_rows DESC\nLIMIT 500\n",
      "parameters": []
    },
    {
      "name": "d010",
      "displayName": "bronze_total",
      "query": "SELECT COUNT(*) AS row_count FROM users.ankur_nayyar.wearables_zerobus",
      "parameters": []
    }
  ],
